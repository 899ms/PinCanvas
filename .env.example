# ========================================
# PinCanvas - 环境变量配置模板
# ========================================
# 复制此文件为 .env 并填入真实值

# ------------------------------------------
# 对象存储 (S3 兼容) 配置
# ------------------------------------------
# 用于存储用户上传的图片、视频等媒体文件
# 任何 S3 兼容的对象存储均可，例如：
#   - AWS S3 (https://aws.amazon.com/s3/)
#   - Cloudflare R2 (https://developers.cloudflare.com/r2/)
#   - 火山引擎 TOS (https://www.volcengine.com/product/TOS)
#   - 阿里云 OSS (https://www.aliyun.com/product/oss)
#   - MinIO (自托管)

# 区域（如 cn-beijing, us-east-1）
TOS_REGION=cn-beijing

# 存储桶名称
TOS_BUCKET=your-bucket-name

# S3 兼容端点
TOS_ENDPOINT=https://your-s3-endpoint.example.com

# 公共访问基础 URL（用于生成可访问的文件链接）
TOS_PUBLIC_BASE_URL=https://your-bucket.your-cdn.example.com

# 访问密钥 ID
TOS_ACCESS_KEY_ID=your-access-key-id

# 访问密钥 Secret
TOS_SECRET_ACCESS_KEY=your-secret-access-key

# 存储命名空间盐值（用于生成唯一的文件路径，建议使用随机字符串）
STORAGE_NAMESPACE_SALT=change-this-to-random-string

# ------------------------------------------
# 开发服务器配置
# ------------------------------------------
# 后端服务端口（可选，默认 8787）
# PORT=8787
